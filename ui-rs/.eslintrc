{
  "extends": "@folio/eslint-config-stripes",
  "rules": {
    "react/prop-types": "off"
  },
  "overrides": [
    {
      "files": [ "src/**/tests/*", "src/test/**/*", "*.test.js", "test/**/*" ],
      "rules": {
        "import/no-extraneous-dependencies": ["error", { "packageDir": [".", ".."] }],
        "import/prefer-default-export": "off",
        "global-require": "off"
      }
    }
  ],
  "env": {
    "jest": true
  }
}
